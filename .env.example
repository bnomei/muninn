# Muninn runtime environment.
# Shell environment values override this file, and both override provider secrets in config.toml.
# Empty values are treated as unset by provider secret resolution.

# Config path resolution.
# If unset, Muninn uses $XDG_CONFIG_HOME/muninn/config.toml, then ~/.config/muninn/config.toml.
MUNINN_CONFIG=
XDG_CONFIG_HOME=

# Dotenv loading is enabled by default for ./.env in the current working directory.
# Set this outside .env before starting Muninn to disable loading this file: 0, false, or no.
# MUNINN_LOAD_DOTENV=0

# Tracing filter for stderr logs.
# Examples: info, debug, recording=debug,provider=debug
RUST_LOG=

# OpenAI is used by the OpenAI STT leg and the default refine pass.
OPENAI_API_KEY=

# Deepgram STT.
DEEPGRAM_API_KEY=
DEEPGRAM_STT_ENDPOINT=
DEEPGRAM_STT_MODEL=
DEEPGRAM_STT_LANGUAGE=

# Google STT. Use either GOOGLE_API_KEY or GOOGLE_STT_TOKEN.
GOOGLE_API_KEY=
GOOGLE_STT_TOKEN=
GOOGLE_STT_ENDPOINT=
GOOGLE_STT_MODEL=

# Optional live-provider bypasses for local smoke tests.
MUNINN_DEEPGRAM_STUB_TEXT=
MUNINN_OPENAI_STUB_TEXT=
MUNINN_GOOGLE_STUB_TEXT=
MUNINN_REFINE_STUB_TEXT=

# Repo tooling variables.
# These are read by shell scripts when exported by your shell; the Muninn app does not read them.
# BIN_NAME=muninn
# PRODUCT_NAME=Muninn
# BUNDLE_IDENTIFIER=com.bnomei.muninn
# OUT_DIR=dist
# INFO_PLIST_TEMPLATE=packaging/macos/Info.plist.template
# ICON_PATH=packaging/macos/Muninn.icns
# VERSION=
# TARGET=
# BIN_PATH=
# MICROPHONE_USAGE_DESCRIPTION=Muninn needs microphone access for dictation.
# CODESIGN_APP=1
# CODESIGN_IDENTITY=-
# ZIP_APP=1
# HOMEBREW_RELEASE_REPO=bnomei/muninn
# HOMEBREW_FORMULA_PATH=packaging/homebrew/Formula/muninn.rb
# HOMEBREW_ASSET_NAME=muninn
